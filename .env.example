# Copy this file to .env and fill in your own values.

# Port the server listens on (most hosts set this automatically).
PORT=3000

# Secret used to sign admin login tokens. Use a long random string in production!
JWT_SECRET=please-change-this-to-a-long-random-string

# Default admin account created on first launch.
ADMIN_EMAIL=admin@proimplant.az
ADMIN_PASSWORD=proimplant123

# Where the JSON database file is stored (defaults to ./data).
# On Render/VPS point this at a persistent disk. Locally, keep it OUTSIDE any
# cloud-synced folder (OneDrive/Dropbox) so sync can't roll it back.
# DATA_DIR=/var/data

# ---------------------------------------------------------------------------
# EMAIL notifications (sent to the doctor when a new appointment is booked).
# Optional — if left unset, notifications are just logged to the console.
# Example below is for Gmail (use an "App password", not your login password).
# ---------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourclinic@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=ProImplant <yourclinic@gmail.com>

# ---------------------------------------------------------------------------
# SMS notifications (sent to the patient when an appointment is confirmed,
# cancelled or completed). Optional — uses Twilio. If unset, logged only.
# ---------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM=+1234567890
