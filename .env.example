# Copy this file to .env and fill in your own values.

# Port the server listens on (most hosts set this automatically).
PORT=3000

# Secret used to sign admin login tokens. Use a long random string in production!
JWT_SECRET=please-change-this-to-a-long-random-string

# Default admin account created on first launch.
ADMIN_EMAIL=admin@proimplant.az
ADMIN_PASSWORD=proimplant123

# Optional: where the JSON database file is stored (defaults to ./data).
# DATA_DIR=/var/data
